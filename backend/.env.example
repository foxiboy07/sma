# DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/flowpulse
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# REDIS
REDIS_URL=redis://localhost:6379
REDIS_CLUSTER_ENABLED=false

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_KMS_KEY_ID=
AWS_S3_WEBHOOK_VAULT_BUCKET=flowpulse-webhook-vault
AWS_SQS_MAIN_QUEUE_URL=
AWS_SQS_DLQ_URL=

# SECURITY
JWT_SECRET=
JWT_EXPIRY=7d
ENCRYPTION_SALT_ROUNDS=12

# META (PARENT APP)
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_API_VERSION=v19.0

# TIKTOK (PARENT APP)
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_WEBHOOK_SECRET=

# AI MODELS
OPENAI_API_KEY=
GOOGLE_GENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_TIER_1_MODEL=gpt-4o-mini
AI_TIER_2_MODEL=gpt-4o

# EXTERNAL SERVICES
SHOPIFY_ACCESS_TOKEN=
CALENDLY_API_KEY=
TIKTOK_SHOP_API_KEY=

# FEATURE FLAGS
FEATURE_CUSTOM_CODE_BLOCKS=true
FEATURE_GHOST_A_B=true
FEATURE_TIKTOK_SHOP=true
FEATURE_SEMANTIC_CACHE=true

# LOGGING
LOG_LEVEL=info
NODE_ENV=development

# SERVICE URLS
INGRESSOR_BASE_URL=http://localhost:3002
WORKER_BASE_URL=http://localhost:3003
WEBSOCKET_URL=ws://localhost:3004

# ANALYTICS
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=flowpulse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# STRIPE
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ENVIRONMENT
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
