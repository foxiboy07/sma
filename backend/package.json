{
  "name": "flowpulse-backend",
  "version": "1.0.0",
  "description": "FlowPulse - Multi-channel DM automation & CRM platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build && tsc --noEmit",
