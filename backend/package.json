    "db:seed": "node scripts/seed.js",
    "seed:dev": "ts-node scripts/seed.ts"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.3.0",
    "pg": "^8.11.0",
    "pg-boss": "^9.2.0",
    "ioredis": "^5.3.0",
    "aws-sdk": "^2.1600.0",
    "@aws-sdk/client-kms": "^3.500.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/client-sqs": "^3.500.0",
    "@aws-sdk/client-lambda": "^3.500.0",
    "crypto-js": "^4.2.0",
    "jose": "^5.0.0",
    "axios": "^1.6.0",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
